# 복사해서 .env 로 저장하거나, export 해서 사용하세요.
# 키가 없으면 자동으로 mock/sample 모드로 "끝까지" 동작합니다.

# 실제 GPT 호출 (없으면 규칙 기반 mock 응답)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 실제 YouTube Data API v3 (없으면 샘플 영상/자막)
# https://console.cloud.google.com → YouTube Data API v3 사용 설정 → API 키 발급
YOUTUBE_API_KEY=

# Streamlit 이 호출할 백엔드 주소 (기본값 그대로 두면 됩니다)
LINGUALOOP_API=http://localhost:8000

# 회원가입 이메일 인증 발송용 SMTP (없으면 자동으로 "데모 모드" —
# 실제 발송 대신 인증 코드를 화면에 직접 보여줍니다)
# 예: Gmail 이라면 SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, 앱 비밀번호 사용
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
